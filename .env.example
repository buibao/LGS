# Shared environment template
# Use this file as a reference only.
# Do not commit real secrets.

# Neon / Vercel Postgres
# Pooled connection string for application runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.neon.tech/DB?sslmode=require"

# Direct/unpooled connection string for Prisma migrations.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.neon.tech/DB?sslmode=require"

# Clerk keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_or_pk_live_xxx"
CLERK_SECRET_KEY="sk_test_or_sk_live_xxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/vi/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/vi/dashboard"
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/vi/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/vi/dashboard"

# App URL
# Use an explicit URL locally or in production when desired.
# In Vercel Preview, this may be omitted because preview URLs are dynamic.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
