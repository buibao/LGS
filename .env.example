# `DATABASE_URL` is the pooled Neon/Vercel connection string for application runtime.
# Use the pooled connection string. Include `sslmode=require` if required by the provider.
DATABASE_URL="postgresql://USER:PASSWORD@EP-POOLER-REGION-pooler.neon.tech/leadops_ai?sslmode=require"
# `DATABASE_URL_UNPOOLED` is the unpooled/direct connection string for Prisma migrations.
# Use the direct connection string without `-pooler`. Include `sslmode=require` if required by the provider.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@EP-DIRECT-REGION.neon.tech/leadops_ai?sslmode=require"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
# Local development can use Clerk test keys.
# Before deploying, replace pk_test_/sk_test_ with your Clerk live production keys.
