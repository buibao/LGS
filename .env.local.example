# Local development environment template
# Never commit real secrets in `.env.local`.
# DATABASE_URL is the pooled Neon/Vercel connection string for application runtime.
# DATABASE_URL_UNPOOLED is the direct/unpooled connection string for Prisma migrations.
# Include sslmode=require if required by your database provider.

DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.neon.tech/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.neon.tech/DB?sslmode=require"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
