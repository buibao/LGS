# Generic Vercel environment template
# Copy values into the Vercel dashboard for the target environment.
# Do not commit real secrets.

# Neon / Vercel Postgres
# Pooled connection string for application runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.neon.tech/DB?sslmode=require"

# Direct/unpooled connection string for Prisma migrations.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.neon.tech/DB?sslmode=require"

# Clerk keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_or_pk_test_xxx"
CLERK_SECRET_KEY="sk_live_or_sk_test_xxx"

# App URL
# Optional in Preview because Vercel preview URLs are dynamic.
# Recommended in Production when you want a stable canonical origin.
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
